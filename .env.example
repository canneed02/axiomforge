# Runtime config. Do not commit real secrets.
AXIOMFORGE_ROOT=/root/axiomforge-state
AXIOMFORGE_PUBLICATION_MODE=local
AXIOMFORGE_AGENT_ID=axiomforge-autonomous-system
AXIOMFORGE_PROVIDER_MODE=offline
AXIOMFORGE_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AXIOMFORGE_NVIDIA_MODELS=moonshotai/kimi-k2.6,mistralai/mistral-large-3-675b-instruct-2512,meta/llama-4-maverick-17b-128e-instruct

# Runtime secrets live outside git, for example:
# NVIDIA_API_KEY_1=...
# NVIDIA_API_KEY_2=...
# NVIDIA_API_KEY_3=...
